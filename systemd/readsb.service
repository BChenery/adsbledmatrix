[Unit]
Description=readsb ADS-B receiver
After=network.target

[Service]
Type=simple
User=adsb
Group=adsb
ExecStart=/usr/local/bin/readsb \
  --device-type rtlsdr \
  --gain -30 \
  --ppm 0 \
  --net \
  --net-sbs-port 30003 \
  --net-beast-reduce-interval 0.5 \
  --write-json-every 1 \
  --quiet
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
